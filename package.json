{
  "name": "sentinel-erp",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "npm run dev:next",
    "dev:next": "next dev",
    "dev:local": "node scripts/run-dev-with-supabase-env.mjs local",
    "dev:remote": "node scripts/run-dev-with-supabase-env.mjs remote",
    "doctor": "node scripts/doctor.mjs",
    "doctor:local": "node scripts/doctor.mjs --expect=local",
    "doctor:remote": "node scripts/doctor.mjs --expect=remote",
    "prebuild": "node scripts/generate-changelog.mjs",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "npx vitest run",
    "test:watch": "npx vitest",
    "test:tina": "npx vitest run src/tina/__tests__",
    "test:tina:adversarial": "npx vitest run src/tina/__tests__/adversarial-gauntlet.test.ts src/tina/__tests__/issue-queue.test.ts src/tina/__tests__/research-policy.test.ts src/tina/__tests__/package-readiness.test.ts",
    "test:smoke": "npx playwright test --config e2e/playwright.config.ts --project smoke",
    "test:smoke:dial-queue": "npx playwright test --config e2e/playwright.config.ts e2e/tests/smoke/leads-dial-queue.spec.ts --project smoke",
    "typecheck": "tsc --noEmit",
    "db:start": "node scripts/supabase-cli.mjs start",
    "db:stop": "node scripts/supabase-cli.mjs stop",
    "db:status": "node scripts/supabase-cli.mjs status",
    "db:reset": "node scripts/supabase-cli.mjs db reset",
    "db:seed:auth": "node scripts/seed-local-auth-users.mjs",
    "ux:access:local": "node scripts/setup-local-ux-access.mjs",
    "ux:access:reset": "node scripts/setup-local-ux-access.mjs --reset-db",
    "env:use:local-supabase": "node scripts/switch-supabase-env.mjs local",
    "env:use:remote-supabase": "node scripts/switch-supabase-env.mjs remote",
    "db:link": "node scripts/supabase-cli.mjs link",
    "db:migration:list": "node scripts/supabase-cli.mjs migration list",
    "db:push": "node scripts/supabase-remote-push.mjs",
    "db:gen-types": "node scripts/supabase-cli.mjs gen types --lang=typescript --project-id imusghlptroddfeycpei > src/lib/supabase-generated-types.ts"
  },
