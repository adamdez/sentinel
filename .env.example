# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Vercel Cron authentication
CRON_SECRET=your-cron-secret

# Google Gmail OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
# Note: encryption key for Gmail tokens is derived from GOOGLE_CLIENT_SECRET automatically

# Twilio (Power Dialer + SMS + VoIP)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX
# Per-user Twilio numbers (optional)
TWILIO_PHONE_NUMBER_ADAM=+1XXXXXXXXXX
TWILIO_PHONE_NUMBER_LOGAN=+1XXXXXXXXXX
TWILIO_PHONE_NUMBER_NATHAN=+1XXXXXXXXXX
# VoIP (run POST /api/twilio/setup to generate these)
TWILIO_API_KEY_SID=SKxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_API_KEY_SECRET=your-api-key-secret
TWILIO_TWIML_APP_SID=APxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# PropertyRadar
PROPERTYRADAR_API_KEY=your-propertyradar-key

# Bricked AI (comps, ARV, repair estimates — $49/mo)
BRICKED_API_KEY=your-bricked-api-key

# OpenAI (dialer AI lanes: summarize, pre-call brief, draft-note, QA)
OPENAI_API_KEY=your-openai-api-key

# Dialer AI lane provider/model config (optional overrides)
# DIALER_AI_PROVIDER defaults to "openai"
DIALER_AI_PROVIDER=openai
# Fast call-adjacent assistance (default): gpt-5-mini
DIALER_AI_MODEL_FAST=gpt-5-mini
# Heavier reasoning/synthesis (default): gpt-5.4
DIALER_AI_MODEL_HEAVY=gpt-5.4
# Optional per-lane overrides
# DIALER_AI_MODEL_PRE_CALL_BRIEF=gpt-5.4
# DIALER_AI_MODEL_SUMMARIZE=gpt-5-mini
# DIALER_AI_MODEL_DRAFT_NOTE=gpt-5-mini
# DIALER_AI_MODEL_QA_NOTES=gpt-5-mini

# Grok Command Center (non-dialer AI surfaces)
# Keep if /grok chat/insights/troubleshoot routes are enabled.
GROK_API_KEY=your-grok-api-key

# REQUIRED for escalation routing. Adam's Supabase user UUID.
# If missing, escalation review saves will fail with HTTP 500.
# Must also be set in Vercel project environment variables for production.
ESCALATION_TARGET_USER_ID=your-admin-user-uuid

# Comma-separated Supabase user UUIDs for Logan and Adam.
# Skip-trace intel fires automatically when a lead is assigned/reassigned to a founder.
# If empty, skip-trace still fires on first claim (null → any user) but not on reassignment.
FOUNDER_USER_IDS=logan-uuid,adam-uuid

# Inbound intake — shared secret for external vendor/webform integrations.
# If set, external callers can POST to /api/inbound/* with X-INTAKE-SECRET header.
# If unset, all inbound endpoints require a valid Supabase Bearer token.
INBOUND_INTAKE_SECRET=

# Google Ads API (for Ads Command Center sync)
GOOGLE_ADS_CLIENT_ID=your-google-ads-client-id
GOOGLE_ADS_CLIENT_SECRET=your-google-ads-client-secret
GOOGLE_ADS_DEVELOPER_TOKEN=your-developer-token
GOOGLE_ADS_CUSTOMER_ID=your-customer-id
GOOGLE_ADS_LOGIN_CUSTOMER_ID=your-mcc-manager-id
GOOGLE_ADS_REFRESH_TOKEN=your-refresh-token

# Deepgram — Real-time call transcription (WI-1)
DEEPGRAM_API_KEY=your-deepgram-api-key
# Shared secret for the Deepgram transcript webhook (relay → /api/webhooks/deepgram)
DEEPGRAM_WEBHOOK_SECRET=your-webhook-shared-secret
# WebSocket URL of the Twilio-to-Deepgram media stream relay server
# TRANSCRIPTION_WS_URL=wss://sentinel-transcription.fly.dev/media-stream
# STT provider selection (stub | deepgram | assemblyai | whisper)
STT_PROVIDER=deepgram

# Site URL (auto-detected on Vercel)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Langfuse — Agent Observability (already installed: langfuse@3.38.6)
LANGFUSE_PUBLIC_KEY=pk-lf-your-public-key-here
LANGFUSE_SECRET_KEY=sk-lf-your-secret-key-here
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# Inngest — Durable Job Queue (Vercel-native, zero infrastructure)
INNGEST_SIGNING_KEY=signkey-prod-your-signing-key-here
INNGEST_EVENT_KEY=your-inngest-event-key-here

# ATTOM — Property data enrichment (fallback to PropertyRadar)
ATTOM_API_KEY=your-attom-api-key

# Firecrawl — Web scraping for deep research and legal searches
FIRECRAWL_API_KEY=your-firecrawl-api-key

# BatchData — Skip trace (phone/email lookup)
BATCHDATA_API_TOKEN=your-batchdata-token

# Tracerfy — Skip trace alternative
TRACERFY_API_KEY=your-tracerfy-api-key

# Apify — Secondary property photo scraping (Zillow interior photos)
APIFY_API_TOKEN=your-apify-token

# Anthropic — Agent AI (research, follow-up, dispo agents)
ANTHROPIC_API_KEY=your-anthropic-api-key

# Vapi — Voice AI front office
VAPI_API_KEY=your-vapi-api-key
VAPI_ASSISTANT_ID=your-vapi-assistant-id
VAPI_PHONE_NUMBER=+1XXXXXXXXXX
VAPI_WEBHOOK_SECRET=your-vapi-webhook-secret

# n8n — Workflow automation delivery
N8N_WEBHOOK_BASE_URL=https://your-n8n-instance.com/webhook
N8N_WEBHOOK_SECRET=your-n8n-shared-secret

# Slack — Alert notifications
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url

# SMS notifications
ADAM_CELL=+1XXXXXXXXXX
NOTIFY_SMS_NUMBERS=+1XXXXXXXXXX

# OpenClaw — Multi-agent research gateway
OPENCLAW_API_URL=https://your-openclaw-instance.fly.dev
OPENCLAW_API_KEY=your-openclaw-api-key

# Google Street View — Property imagery
GOOGLE_STREET_VIEW_KEY=your-google-maps-api-key

# Perplexity — Research agent web search (optional, graceful degradation)
# PERPLEXITY_API_KEY=your-perplexity-key
