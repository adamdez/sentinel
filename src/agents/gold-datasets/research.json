          "severity": "fail"
        },
        {
          "name": "dossier_exists",
          "type": "field_exists",
          "field": "dossier",
          "severity": "fail"
        },
        {
          "name": "situation_summary_present",
          "type": "field_min_length",
          "field": "dossier.situationSummary",
