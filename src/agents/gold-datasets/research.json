      "checks": [
        {
          "name": "has_at_least_one_artifact",
          "type": "field_min_count",
          "field": "artifacts",
          "min": 1,
          "severity": "fail"
        },
        {
          "name": "has_at_least_one_fact",
          "type": "field_min_count",
