# Remote/production Supabase values belong in your private `.env.local`.
# The local switch script creates `.env.local.remote.backup` from your current file,
# then restores from that backup when you run `npm run env:use:remote-supabase`.

NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-remote-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-remote-service-role-key"
DATABASE_URL="postgresql://postgres:[YOUR_SUPABASE_PASSWORD]@db.your-project.supabase.co:5432/postgres"
